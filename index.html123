<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Universal AI Chat - Liquid Glass UI</title>

<!-- Tailwind CSS CDN -->
<script src="https://cdn.tailwindcss.com"></script>
<script>tailwind.config={darkMode:'class'}</script>

<!-- Marked.js CDN for Markdown rendering -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
/* ------------------------ */
/* Liquid Glass iOS 17 Style */
/* ------------------------ */
html, body {height:100%; margin:0; font-family:sans-serif;}
#loading{position:fixed; inset:0; display:flex; justify-content:center; align-items:center; font-size:1.5rem; font-weight:bold; background:#f9f9f9; color:#111; z-index:50;}
body.dark #loading{background:#111; color:#fff;}

/* Glass panels */
.glass{
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(20px) saturate(180%);
  border-radius:1.5rem;
  border:1px solid rgba(255,255,255,0.2);
  box-shadow:0 8px 32px rgba(0,0,0,0.15);
  transition: background 0.3s;
}
.dark .glass{
  background: rgba(25,25,25,0.3);
  border:1px solid rgba(255,255,255,0.05);
  box-shadow:0 8px 32px rgba(0,0,0,0.3);
}

/* Chat messages */
.message{display:flex; width:100%;}
.message-bubble{
  padding:0.75rem 1rem;
  border-radius:1.5rem;
  max-width:75%;
  word-wrap:break-word;
  opacity:0; transform:translateY(20px);
  transition: all 0.4s ease;
}
.message-bubble.animate{opacity:1; transform:translateY(0);}
.message.user .message-bubble{align-self:flex-end; background:linear-gradient(135deg,#4facfe,#00f2fe); color:white;}
.message.ai .message-bubble{align-self:flex-start; background:rgba(255,255,255,0.2); color:#111;}
.dark .message.ai .message-bubble{background:rgba(50,50,50,0.3); color:white;}
.typing-cursor::after{content:"|"; animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
</style>
</head>
<body class="min-h-screen flex bg-gray-100 dark:bg-gray-900">

<div id="loading">Loading App...</div>

<!-- Sidebar -->
<div id="sidebar" class="fixed md:relative z-40 w-72 glass h-full transform -translate-x-full md:translate-x-0 transition-transform duration-300 flex flex-col">
  <div class="p-4 border-b border-white/20 flex justify-between items-center">
    <span class="font-bold text-lg">Chats</span>
    <button id="closeSidebar" class="md:hidden text-xl">✕</button>
  </div>
  <div class="p-3">
    <button id="newChat" class="w-full gradient-btn py-2 rounded-lg text-white font-semibold">+ New Chat</button>
  </div>
  <div id="chatList" class="flex-1 overflow-y-auto px-2 pb-4 space-y-2"></div>
  <div class="p-4 border-t border-white/20 space-y-2">
    <button id="settingsBtn" class="w-full glass py-2 rounded text-sm">Settings</button>
    <button id="darkToggle" class="w-full glass py-2 rounded text-sm">Toggle Dark</button>
  </div>
</div>

<!-- Main Chat Area -->
<div class="flex-1 flex flex-col w-full">
  <div class="flex items-center p-4 border-b border-white/20 glass">
    <button id="openSidebar" class="md:hidden text-2xl mr-4">☰</button>
    <h1 id="chatTitle" class="font-semibold text-lg">New Chat</h1>
  </div>

  <div id="messages" class="flex-1 overflow-y-auto p-4 space-y-4 flex flex-col"></div>

  <div class="sticky bottom-0 glass p-3">
    <div class="flex gap-2">
      <textarea id="messageInput" rows="1" class="flex-1 resize-none p-3 rounded-lg border dark:bg-gray-700 dark:border-gray-600" placeholder="Message AI..."></textarea>
      <button id="sendBtn" class="px-5 rounded-lg bg-gradient-to-r from-purple-500 via-pink-500 to-red-500 text-white font-semibold">Send</button>
    </div>
  </div>
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">
  <div class="bg-white dark:bg-gray-800 w-96 p-6 rounded-lg space-y-4 glass">
    <h2 class="text-lg font-semibold">Settings</h2>
    <input id="apiKeyInput" type="password" placeholder="OpenRouter API Key" class="w-full p-2 border rounded dark:bg-gray-700">
    <input id="modelInput" type="text" value="deepseek/deepseek-r1:free" class="w-full p-2 border rounded dark:bg-gray-700">
    <textarea id="systemPromptInput" rows="3" placeholder="System Prompt (optional)" class="w-full p-2 border rounded dark:bg-gray-700"></textarea>
    <div class="flex justify-end gap-2">
      <button id="saveSettings" class="px-4 py-2 rounded bg-gradient-to-r from-purple-500 via-pink-500 to-red-500 text-white font-semibold">Save</button>
      <button id="closeSettings" class="px-4 py-2 rounded bg-gray-300 dark:bg-gray-600 text-black dark:text-white">Close</button>
    </div>
  </div>
</div>

<script>
(function(){
const loading=document.getElementById("loading");
try{
let state={
  apiKey: localStorage.getItem("apiKey")||"",
  model: localStorage.getItem("model")||"deepseek/deepseek-r1:free",
  chats: JSON.parse(localStorage.getItem("chats")||"[]"),
  activeChatId: localStorage.getItem("activeChatId")||null,
  dark: localStorage.getItem("darkMode")==="true"
};
if(state.dark) document.documentElement.classList.add("dark");

function saveState(){
  localStorage.setItem("apiKey",state.apiKey);
  localStorage.setItem("model",state.model);
  localStorage.setItem("chats",JSON.stringify(state.chats));
  localStorage.setItem("activeChatId",state.activeChatId);
  localStorage.setItem("darkMode",state.dark);
}

function createChat(){const id=Date.now().toString(); const chat={id,title:"New Chat",messages:[],systemPrompt:""}; state.chats.unshift(chat); state.activeChatId=id; saveState(); renderChatList(); renderMessages();}
function getActiveChat(){return state.chats.find(c=>c.id===state.activeChatId);}
function renderChatList(){
const list=document.getElementById("chatList"); list.innerHTML="";
state.chats.forEach(chat=>{
const div=document.createElement("div");
div.className="p-2 rounded cursor-pointer glass flex justify-between items-center";
div.innerHTML=`<span class="truncate">${chat.title}</span><div class="flex gap-1"><button class="rename text-xs">✏</button><button class="delete text-xs">🗑</button></div>`;
div.onclick=()=>{state.activeChatId=chat.id; saveState(); renderMessages();};
div.querySelector(".delete").onclick=(e)=>{e.stopPropagation(); state.chats=state.chats.filter(c=>c.id!==chat.id); if(state.activeChatId===chat.id) state.activeChatId=state.chats[0]?.id||null; saveState(); renderChatList(); renderMessages();};
div.querySelector(".rename").onclick=(e)=>{e.stopPropagation(); const name=prompt("Rename chat:",chat.title); if(name){chat.title=name; saveState(); renderChatList();}};
list.appendChild(div);
});
}
function renderMessages(){
const chat=getActiveChat(); const container=document.getElementById("messages"); container.innerHTML="";
if(!chat){document.getElementById("chatTitle").textContent="New Chat"; return;}
document.getElementById("chatTitle").textContent=chat.title;
chat.messages.forEach(msg=>{
const div=document.createElement("div"); div.className="message "+msg.role;
const bubble=document.createElement("div"); bubble.className="message-bubble "+(msg.role==="user"?"bg-blue-500 text-white":"bg-gray-200 dark:bg-gray-700"); bubble.innerHTML=marked.parse(msg.content);
div.appendChild(bubble); container.appendChild(div);
setTimeout(()=>bubble.classList.add("animate"),10);
});
container.scrollTop=container.scrollHeight;
}

async function sendMessage(){
const input=document.getElementById("messageInput"); const text=input.value.trim();
if(!text) return; if(!state.apiKey){alert("Add API key in settings."); return;}
let chat=getActiveChat(); if(!chat){createChat(); chat=getActiveChat();}
chat.messages.push({role:"user",content:text}); input.value=""; renderMessages();
const aiMessage={role:"assistant",content:""}; chat.messages.push(aiMessage); renderMessages();
const container=document.getElementById("messages"); const aiDiv=container.lastChild.querySelector("div");
try{
const response=await fetch("https://openrouter.ai/api/v1/chat/completions",{method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+state.apiKey},body:JSON.stringify({model:state.model,messages:[...(chat.systemPrompt?[{role:"system",content:chat.systemPrompt}]:[]),...chat.messages.filter(m=>m.role!=="assistant")],stream:true})});
const reader=response.body.getReader(); const decoder=new TextDecoder("utf-8");
while(true){
const {done,value}=await reader.read(); if(done) break;
const chunk=decoder.decode(value);
chunk.split("\n").forEach(line=>{
if(line.startsWith("data: ")&&!line.includes("[DONE]")){
try{const json=JSON.parse(line.replace("data: ","")); const token=json.choices?.[0]?.delta?.content; if(token){aiMessage.content+=token; aiDiv.innerHTML=marked.parse(aiMessage.content)+'<span class="typing-cursor"></span>'; container.scrollTop=container.scrollHeight;}}catch{}
}
});
}
aiDiv.innerHTML=marked.parse(aiMessage.content); saveState();
}catch(err){aiDiv.innerHTML="Error occurred.";}
}

document.getElementById("sendBtn").onclick=sendMessage;
document.getElementById("messageInput").addEventListener("keydown",e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault(); sendMessage();}});
document.getElementById("newChat").onclick=createChat;
document.getElementById("settingsBtn").onclick=()=>{document.getElementById("settingsModal").classList.remove("hidden"); document.getElementById("apiKeyInput").value=state.apiKey; document.getElementById("modelInput").value=state.model; document.getElementById("systemPromptInput").value=getActiveChat()?.systemPrompt||"";};
document.getElementById("closeSettings").onclick=()=>{document.getElementById("settingsModal").classList.add("hidden");};
document.getElementById("saveSettings").onclick=()=>{state.apiKey=document.getElementById("apiKeyInput").value.trim(); state.model=document.getElementById("modelInput").value.trim(); const chat=getActiveChat(); if(chat){chat.systemPrompt=document.getElementById("systemPromptInput").value;} saveState(); document.getElementById("settingsModal").classList.add("hidden");};
document.getElementById("darkToggle").onclick=()=>{state.dark=!state.dark; document.documentElement.classList.toggle("dark"); saveState();};
document.getElementById("openSidebar").onclick=()=>{document.getElementById("sidebar").classList.remove("-translate-x-full");};
document.getElementById("closeSidebar").onclick=()=>{document.getElementById("sidebar").classList.add("-translate-x-full");};

if(!state.activeChatId && state.chats.length){state.activeChatId=state.chats[0].id;}
renderChatList(); renderMessages(); loading.style.display="none";

}catch(e){console.error(e); loading.innerText="App failed to load.";}
})();
</script>

</body>
</html>
